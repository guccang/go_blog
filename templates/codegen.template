<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CodeGen - AI 编程助手</title>
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-primary: #0d1117;
            --bg-secondary: #161b22;
            --bg-tertiary: #21262d;
            --bg-hover: #30363d;
            --border: #30363d;
            --text-primary: #e6edf3;
            --text-secondary: #8b949e;
            --text-muted: #484f58;
            --accent: #58a6ff;
            --accent-hover: #79c0ff;
            --green: #3fb950;
            --yellow: #d29922;
            --red: #f85149;
            --purple: #bc8cff;
            --orange: #f0883e;
            --cyan: #39d2c0;
            --radius: 8px;
            --font-mono: 'JetBrains Mono', 'Consolas', monospace;
            --font-sans: 'Inter', -apple-system, sans-serif;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: var(--font-sans);
            background: var(--bg-primary);
            color: var(--text-primary);
            height: 100vh;
            overflow: hidden;
        }

        /* Layout */
        .app {
            display: grid;
            grid-template-columns: 280px 1fr;
            grid-template-rows: 56px 1fr;
            height: 100vh;
        }

        /* Header */
        .header {
            grid-column: 1 / -1;
            background: var(--bg-secondary);
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            padding: 0 20px;
            gap: 16px;
        }
        .header h1 {
            font-size: 18px;
            font-weight: 600;
            background: linear-gradient(135deg, var(--accent), var(--purple));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
        .header .badge {
            background: var(--bg-tertiary);
            border: 1px solid var(--border);
            padding: 2px 10px;
            border-radius: 12px;
            font-size: 11px;
            color: var(--text-secondary);
        }
        .header .workspace-path {
            margin-left: auto;
            font-family: var(--font-mono);
            font-size: 12px;
            color: var(--text-muted);
        }
        .header .btn-home {
            background: var(--bg-tertiary);
            border: 1px solid var(--border);
            color: var(--text-secondary);
            padding: 6px 14px;
            border-radius: var(--radius);
            cursor: pointer;
            font-size: 13px;
            text-decoration: none;
            transition: all 0.2s;
        }
        .header .btn-home:hover {
            background: var(--bg-hover);
            color: var(--text-primary);
        }

        /* Sidebar */
        .sidebar {
            background: var(--bg-secondary);
            border-right: 1px solid var(--border);
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }
        .sidebar-header {
            padding: 12px 16px;
            border-bottom: 1px solid var(--border);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .sidebar-header h3 {
            font-size: 13px;
            font-weight: 600;
            color: var(--text-secondary);
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        .btn-new {
            background: var(--accent);
            color: #fff;
            border: none;
            padding: 4px 12px;
            border-radius: var(--radius);
            font-size: 12px;
            cursor: pointer;
            font-weight: 500;
            transition: background 0.2s;
        }
        .btn-new:hover { background: var(--accent-hover); }

        .project-list {
            flex: 1;
            overflow-y: auto;
            padding: 8px;
        }
        .project-item {
            padding: 10px 12px;
            border-radius: var(--radius);
            cursor: pointer;
            transition: background 0.15s;
            margin-bottom: 2px;
        }
        .project-item:hover { background: var(--bg-tertiary); }
        .project-item.active {
            background: var(--bg-tertiary);
            border-left: 2px solid var(--accent);
        }
        .project-item .name {
            font-size: 14px;
            font-weight: 500;
            margin-bottom: 2px;
        }
        .project-item .meta {
            font-size: 11px;
            color: var(--text-muted);
        }
        .project-item .agent-badge {
            display: inline-block;
            background: rgba(188, 140, 255, 0.15);
            color: var(--purple);
            font-size: 10px;
            padding: 1px 6px;
            border-radius: 4px;
            margin-left: 6px;
            font-weight: 500;
        }

        /* Agent status */
        .agent-status {
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: 12px;
            color: var(--text-muted);
            margin-left: 12px;
        }
        .agent-status .dot {
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: var(--text-muted);
        }
        .agent-status .dot.online {
            background: var(--green);
        }
        .agent-section-header {
            padding: 8px 12px 4px;
            font-size: 11px;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 0.5px;
            font-weight: 600;
        }

        /* Agent Group (collapsible) */
        .agent-group { margin-bottom: 2px; }
        .agent-group-header {
            display: flex;
            align-items: center;
            gap: 6px;
            padding: 7px 12px;
            cursor: pointer;
            font-size: 12px;
            font-weight: 600;
            color: var(--text-secondary);
            border-radius: var(--radius);
            transition: background 0.15s;
            user-select: none;
        }
        .agent-group-header:hover { background: var(--bg-tertiary); }
        .agent-group-header .arrow {
            font-size: 10px;
            transition: transform 0.2s;
            color: var(--text-muted);
            display: inline-block;
        }
        .agent-group.collapsed .agent-group-header .arrow { transform: rotate(-90deg); }
        .agent-group-header .grp-count {
            font-size: 10px;
            color: var(--text-muted);
            font-weight: 400;
            margin-left: auto;
        }
        .agent-group-body { padding-left: 4px; }
        .agent-group.collapsed .agent-group-body { display: none; }
        .toggle-btns {
            display: flex;
            gap: 4px;
        }
        .toggle-btns button {
            background: none;
            border: 1px solid var(--border);
            color: var(--text-muted);
            padding: 3px 7px;
            border-radius: 4px;
            cursor: pointer;
            font-size: 10px;
            transition: all 0.15s;
            line-height: 1;
        }
        .toggle-btns button:hover {
            background: var(--bg-tertiary);
            color: var(--text-secondary);
        }

        /* Main */
        .main {
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }

        /* Welcome */
        .welcome {
            flex: 1;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 16px;
        }
        .welcome .icon { font-size: 48px; }
        .welcome h2 { font-size: 22px; color: var(--text-primary); }
        .welcome p { color: var(--text-secondary); max-width: 400px; text-align: center; line-height: 1.6; }

        /* Output */
        .output-area {
            flex: 1;
            overflow-y: auto;
            padding: 16px 20px;
            display: none;
        }
        .output-area.active { display: block; }

        .event-item {
            padding: 8px 12px;
            margin-bottom: 4px;
            border-radius: 6px;
            font-size: 13px;
            line-height: 1.5;
            animation: fadeIn 0.3s ease;
        }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(4px); } to { opacity: 1; transform: translateY(0); } }

        .event-item.system {
            color: var(--text-muted);
            font-style: italic;
        }
        .event-item.tool {
            background: rgba(88, 166, 255, 0.08);
            border-left: 3px solid var(--accent);
            font-family: var(--font-mono);
            font-size: 12px;
        }
        .tool-header {
            font-weight: 600;
            color: var(--accent);
            margin-bottom: 4px;
        }
        .tool-detail {
            color: var(--text-secondary);
            white-space: pre-wrap;
            word-break: break-all;
            max-height: 300px;
            overflow-y: auto;
            padding: 4px 0;
            line-height: 1.4;
        }
        .event-item.assistant {
            background: var(--bg-tertiary);
            white-space: pre-wrap;
        }
        .event-item.thinking {
            background: rgba(188, 140, 255, 0.06);
            border-left: 3px solid var(--purple);
            font-size: 12px;
            cursor: pointer;
            user-select: none;
        }
        .event-item.thinking .thinking-header {
            color: var(--purple);
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 6px;
        }
        .event-item.thinking .thinking-header .toggle-icon {
            font-size: 10px;
            transition: transform 0.2s ease;
        }
        .event-item.thinking:not(.collapsed) .thinking-header .toggle-icon {
            transform: rotate(90deg);
        }
        .event-item.thinking .thinking-content {
            color: var(--text-secondary);
            white-space: pre-wrap;
            word-break: break-word;
            margin-top: 6px;
            padding: 6px 8px;
            background: rgba(188, 140, 255, 0.04);
            border-radius: 4px;
            max-height: 400px;
            overflow-y: auto;
            font-family: var(--font-mono);
            line-height: 1.5;
        }
        .event-item.thinking.collapsed .thinking-content {
            display: none;
        }
        .event-item.result {
            background: rgba(63, 185, 80, 0.1);
            border-left: 3px solid var(--green);
            color: var(--green);
        }
        .event-item.error {
            background: rgba(248, 81, 73, 0.1);
            border-left: 3px solid var(--red);
            color: var(--red);
        }
        .event-item .cost {
            float: right;
            color: var(--yellow);
            font-size: 11px;
        }

        /* Status bar */
        .status-bar {
            padding: 6px 20px;
            background: var(--bg-secondary);
            border-top: 1px solid var(--border);
            font-size: 12px;
            color: var(--text-muted);
            display: flex;
            align-items: center;
            gap: 12px;
        }
        .status-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: var(--text-muted);
        }
        .status-dot.running {
            background: var(--green);
            animation: pulse 1.5s infinite;
        }
        @keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.4; } }

        /* Input */
        .input-area {
            padding: 12px 20px;
            background: var(--bg-secondary);
            border-top: 1px solid var(--border);
            display: flex;
            gap: 8px;
        }
        .input-area input {
            flex: 1;
            background: var(--bg-primary);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 10px 16px;
            color: var(--text-primary);
            font-size: 14px;
            font-family: var(--font-sans);
            outline: none;
            transition: border-color 0.2s;
        }
        .input-area input:focus { border-color: var(--accent); }
        .input-area input::placeholder { color: var(--text-muted); }

        .btn-send {
            background: linear-gradient(135deg, var(--accent), var(--purple));
            color: #fff;
            border: none;
            padding: 10px 20px;
            border-radius: var(--radius);
            font-size: 14px;
            font-weight: 500;
            cursor: pointer;
            transition: opacity 0.2s;
            white-space: nowrap;
        }
        .btn-send:hover { opacity: 0.9; }
        .btn-send:disabled { opacity: 0.5; cursor: not-allowed; }

        .btn-stop {
            background: var(--red);
            color: #fff;
            border: none;
            padding: 10px 16px;
            border-radius: var(--radius);
            font-size: 13px;
            cursor: pointer;
            display: none;
        }
        .btn-stop.visible { display: block; }

        .model-select {
            background: var(--bg-primary);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 10px 12px;
            color: var(--text-primary);
            font-size: 13px;
            font-family: var(--font-sans);
            outline: none;
            cursor: pointer;
            min-width: 100px;
            transition: border-color 0.2s;
        }
        .model-select:focus { border-color: var(--accent); }
        .model-select option { background: var(--bg-secondary); color: var(--text-primary); }

        .deploy-checkbox {
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: 13px;
            color: var(--text-secondary);
            cursor: pointer;
            white-space: nowrap;
            padding: 0 4px;
        }
        .deploy-checkbox input[type="checkbox"] {
            accent-color: var(--orange);
            width: 15px;
            height: 15px;
            cursor: pointer;
        }

        /* Modal */
        .modal-overlay {
            position: fixed;
            top: 0; left: 0; right: 0; bottom: 0;
            background: rgba(0,0,0,0.5);
            display: none;
            align-items: center;
            justify-content: center;
            z-index: 100;
        }
        .modal-overlay.active { display: flex; }
        .modal {
            background: var(--bg-secondary);
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 24px;
            width: 400px;
        }
        .modal h3 { margin-bottom: 16px; font-size: 16px; }
        .modal input {
            width: 100%;
            background: var(--bg-primary);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 10px 14px;
            color: var(--text-primary);
            font-size: 14px;
            outline: none;
            margin-bottom: 16px;
        }
        .modal input:focus { border-color: var(--accent); }
        .modal-actions {
            display: flex;
            gap: 8px;
            justify-content: flex-end;
        }
        .modal-actions button {
            padding: 8px 16px;
            border-radius: var(--radius);
            font-size: 13px;
            cursor: pointer;
            border: none;
        }
        .modal-actions .btn-cancel {
            background: var(--bg-tertiary);
            color: var(--text-secondary);
        }
        .modal-actions .btn-confirm {
            background: var(--accent);
            color: #fff;
        }

        /* Scrollbar */
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: var(--bg-hover); border-radius: 3px; }
    </style>
</head>
<body>
    <div class="app">
        <!-- Header -->
        <div class="header">
            <h1>⚡ CodeGen</h1>
            <span class="badge">Claude Code</span>
            <span class="workspace-path" id="workspacePath"></span>
            <div class="agent-status" id="agentStatus" style="display:none">
                <span class="dot" id="agentDot"></span>
                <span id="agentText"></span>
            </div>
            <a href="/main" class="btn-home">← 返回</a>
        </div>

        <!-- Sidebar -->
        <div class="sidebar">
            <div class="sidebar-header">
                <h3>📂 项目</h3>
                <button class="btn-new" onclick="showNewProjectModal()">+ 新建</button>
            </div>
            <div style="padding: 6px 8px; border-bottom: 1px solid var(--border); display: flex; gap: 4px; align-items: center;">
                <input type="text" id="projectSearch" placeholder="搜索项目..."
                       oninput="filterProjects()"
                       style="flex:1; background:var(--bg-primary); border:1px solid var(--border); border-radius:var(--radius); padding:6px 10px; color:var(--text-primary); font-size:12px; outline:none;">
                <div class="toggle-btns">
                    <button onclick="expandAllAgents()" title="展开全部">▼全</button>
                    <button onclick="collapseAllAgents()" title="折叠全部">▶全</button>
                </div>
            </div>
            <div class="project-list" id="projectList">
                <div style="padding: 20px; color: var(--text-muted); text-align: center; font-size: 13px;">
                    加载中...
                </div>
            </div>
        </div>

        <!-- Main -->
        <div class="main">
            <div class="welcome" id="welcomeView">
                <div class="icon">⚡</div>
                <h2>AI 编程助手</h2>
                <p>选择左侧编码项目输入需求，或选择部署项目一键部署。</p>
            </div>

            <div class="output-area" id="outputArea"></div>

            <div class="status-bar" id="statusBar">
                <div class="status-dot" id="statusDot"></div>
                <span id="statusText">就绪</span>
                <span style="margin-left: auto" id="costText"></span>
            </div>

            <div class="input-area" id="codeInputArea">
                <select id="modelSelect" class="model-select" title="选择模型配置">
                    <option value="default">default</option>
                </select>
                <select id="toolSelect" class="model-select" title="选择编码工具" style="min-width:120px;">
                    <option value="">Claude Code</option>
                </select>
                <input type="text" id="promptInput" placeholder="描述编码需求... (如: 创建一个 Go HTTP 服务)">
                <button class="btn-send" id="btnSend" onclick="sendPrompt()">发送</button>
                <button class="btn-stop" id="btnStop" onclick="stopSession()">⏹ 停止</button>
            </div>
            <div class="input-area" id="deployInputArea" style="display:none;">
                <select id="deployTarget" class="model-select" title="部署目标">
                    <option value="">默认目标</option>
                </select>
                <select id="deployPlatform" class="model-select" title="目标平台">
                    <option value="">当前平台</option>
                    <option value="linux">linux</option>
                    <option value="macos">macos</option>
                    <option value="win">win</option>
                </select>
                <label class="deploy-checkbox"><input type="checkbox" id="deployPackOnly"> 仅打包</label>
                <button class="btn-send" id="btnDeployRun" onclick="deployProject()" style="background:linear-gradient(135deg, var(--orange), var(--red)); flex:1;">🚀 部署</button>
                <button class="btn-stop" id="btnDeployStop" onclick="stopSession()">⏹ 停止</button>
            </div>
            <div class="input-area" id="pipelineInputArea" style="display:none;">
                <button class="btn-send" id="btnPipelineRun" onclick="runPipeline()" style="background:linear-gradient(135deg, #667eea, #764ba2); flex:1;">🔄 执行 Pipeline</button>
                <button class="btn-stop" id="btnPipelineStop" onclick="stopSession()">⏹ 停止</button>
            </div>
        </div>
    </div>

    <!-- New Project Modal -->
    <div class="modal-overlay" id="newProjectModal">
        <div class="modal">
            <h3>📁 新建项目</h3>
            <input type="text" id="newProjectName" placeholder="项目名称 (如: my-web-app)">
            <div class="modal-actions">
                <button class="btn-cancel" onclick="hideNewProjectModal()">取消</button>
                <button class="btn-confirm" onclick="createProject()">创建</button>
            </div>
        </div>
    </div>

    <script>
    let currentProject = null;
    let currentSessionId = null;
    let currentMode = 'code'; // 'code', 'deploy', or 'pipeline'
    let currentAgentId = null; // 当前选中项目对应的 agent ID
    let ws = null;
    let remoteProjectMap = {}; // project name -> [{agent_id, agent, tools}] 数组映射
    let cachedLocalProjects = [];
    let cachedRemoteOnly = [];
    let cachedCodingRemote = [];   // 远程项目中支持编码的
    let cachedDeployProjects = []; // 远程项目中支持部署的
    let cachedAllRemote = [];      // 全部远程项目（用于按 agent 分组）
    let expandedAgents = new Set(); // 已展开的 agent 组 ID
    let initialExpandDone = false; // 是否已经完成过初始的自动展开
    let cachedClaudeCodeModels = [];
    let cachedOpenCodeModels = [];

    // 每个项目的会话状态缓存: stateKey -> { sessionId, outputHtml, status, costText }
    // stateKey 格式: 远程项目 "name:agentId", 本地项目 "name"
    let projectStates = {};

    function getStateKey(name, agentId) {
        return agentId ? name + ':' + agentId : name;
    }

    // 页面加载
    document.addEventListener('DOMContentLoaded', async function() {
        await loadProjects();
        await loadRunningSessions();
    });

    // 加载已有运行中的会话
    async function loadRunningSessions() {
        try {
            const resp = await fetch('/api/codegen/sessions');
            const data = await resp.json();
            if (!data.success) return;
            const sessions = data.data.sessions || [];
            for (const s of sessions) {
                const key = getStateKey(s.project, s.agent_id);
                if (!projectStates[key]) {
                    projectStates[key] = { sessionId: null, outputHtml: '', status: 'idle', costText: '' };
                }
                const state = projectStates[key];
                // 保留最新的 session
                if (!state.sessionId || s.status === 'running') {
                    state.sessionId = s.id;
                    state.status = s.status === 'running' ? 'running' : 'done';
                }
            }
            renderProjects();
        } catch (e) { /* ignore */ }
    }

    function getProjectState(project, agentId) {
        const key = getStateKey(project, agentId);
        if (!projectStates[key]) {
            projectStates[key] = { sessionId: null, outputHtml: '', status: 'idle', costText: '' };
        }
        return projectStates[key];
    }

    // 加载项目列表
    async function loadProjects() {
        try {
            const resp = await fetch('/api/codegen/projects');
            const data = await resp.json();
            if (!data.success) throw new Error(data.error);

            document.getElementById('workspacePath').textContent = data.data.workspace;

            // 更新 agent 状态
            updateAgentStatus(data.data.agents || []);

            // 缓存两种模型列表
            cachedClaudeCodeModels = data.data.claudecode_models || [];
            cachedOpenCodeModels = data.data.opencode_models || [];

            // 更新模型选择器（根据当前选择的工具）
            const toolSelect = document.getElementById('toolSelect');
            const currentTool = toolSelect.value;
            const models = currentTool === 'opencode' ? cachedOpenCodeModels : cachedClaudeCodeModels;
            updateModelSelect(models);

            // 更新工具选择器
            updateToolSelect(data.data.tools || []);

            // 合并本地和远程项目
            const localProjects = data.data.projects || [];
            const remoteProjects = data.data.remote_projects || [];
            remoteProjectMap = {};
            remoteProjects.forEach(rp => {
                if (!remoteProjectMap[rp.name]) remoteProjectMap[rp.name] = [];
                remoteProjectMap[rp.name].push(rp);
            });
            cachedAllRemote = remoteProjects;

            // 去重 + 按名称排序（稳定）
            const localNames = new Set(localProjects.map(p => p.name));
            cachedLocalProjects = localProjects.slice().sort((a, b) => a.name.localeCompare(b.name));
            cachedRemoteOnly = remoteProjects
                .filter(rp => !localNames.has(rp.name))
                .sort((a, b) => a.name.localeCompare(b.name));

            // 按 tools 拆分远程项目为编码和部署两组（同名项目按 agent 独立展示，不去重）
            const codingTools = ['claudecode', 'opencode'];
            cachedCodingRemote = remoteProjects
                .filter(rp => rp.tools && rp.tools.some(t => codingTools.includes(t)))
                .sort((a, b) => a.name.localeCompare(b.name) || a.agent.localeCompare(b.agent));
            cachedDeployProjects = remoteProjects
                .filter(rp => rp.tools && rp.tools.includes('deploy'))
                .sort((a, b) => a.name.localeCompare(b.name) || a.agent.localeCompare(b.agent));

            renderProjects();
        } catch (err) {
            console.error('Load projects failed:', err);
        }
    }

    function updateAgentStatus(agents) {
        const el = document.getElementById('agentStatus');
        const dot = document.getElementById('agentDot');
        const text = document.getElementById('agentText');

        if (!agents || agents.length === 0) {
            el.style.display = 'none';
            return;
        }

        el.style.display = 'flex';
        dot.className = 'dot online';
        text.textContent = `${agents.length} Agent 在线`;
    }

    function updateModelSelect(models) {
        const select = document.getElementById('modelSelect');
        const currentVal = select.value;
        // 保留第一个默认选项
        select.innerHTML = '<option value="default">default</option>';
        if (models && models.length > 0) {
            models.forEach(m => {
                if (m === 'default') return; // 已有硬编码的 default 选项
                const opt = document.createElement('option');
                opt.value = m;
                opt.textContent = m;
                select.appendChild(opt);
            });
            select.style.display = '';
        } else {
            select.style.display = 'none';
        }
        // 恢复之前的选择
        if (currentVal) {
            select.value = currentVal;
        }
    }

    function updateToolSelect(tools) {
        const select = document.getElementById('toolSelect');
        const currentVal = select.value;
        const toolLabels = { 'claudecode': 'Claude Code', 'opencode': 'OpenCode' };
        select.innerHTML = '';
        // 默认选项
        const defaultOpt = document.createElement('option');
        defaultOpt.value = '';
        defaultOpt.textContent = 'Claude Code';
        select.appendChild(defaultOpt);
        if (tools && tools.length > 0) {
            tools.forEach(t => {
                if (t === 'claudecode') return; // 已是默认
                const opt = document.createElement('option');
                opt.value = t;
                opt.textContent = toolLabels[t] || t;
                select.appendChild(opt);
            });
            // 只有一个工具时隐藏选择器
            select.style.display = tools.length > 1 ? '' : 'none';
        } else {
            select.style.display = 'none';
        }
        if (currentVal) {
            select.value = currentVal;
        }
        // 添加工具切换事件
        select.onchange = function() {
            updateModelSelectByTool(this.value);
        };
    }

    // 根据工具类型更新模型选择器
    function updateModelSelectByTool(tool) {
        let models = tool === 'opencode' ? cachedOpenCodeModels : cachedClaudeCodeModels;
        updateModelSelect(models || []);
    }

    function filterProjects() {
        renderProjects();
    }

    function toggleAgentGroup(groupId) {
        if (expandedAgents.has(groupId)) {
            expandedAgents.delete(groupId);
        } else {
            expandedAgents.add(groupId);
        }
        renderProjects();
    }

    function expandAllAgents() {
        expandedAgents.add('__local__');
        cachedAllRemote.forEach(rp => expandedAgents.add(rp.agent_id));
        renderProjects();
    }

    function collapseAllAgents() {
        expandedAgents.clear();
        renderProjects();
    }

    function getProjectStatusIndicator(projectName, agentId) {
        const key = getStateKey(projectName, agentId);
        const state = projectStates[key];
        if (!state) return '';
        if (state.status === 'running') {
            return '<span style="display:inline-block;width:6px;height:6px;border-radius:50%;background:var(--green);margin-left:6px;animation:pulse 1.5s infinite;vertical-align:middle;" title="运行中"></span>';
        }
        return '';
    }

    function renderProjects() {
        const list = document.getElementById('projectList');
        const query = (document.getElementById('projectSearch').value || '').toLowerCase().trim();

        let groups = [];

        // 本地项目组
        const localFiltered = cachedLocalProjects.filter(p => !query || p.name.toLowerCase().includes(query));
        if (localFiltered.length > 0) {
            groups.push({
                id: '__local__',
                icon: '💻',
                name: '本地',
                count: localFiltered.length,
                html: localFiltered.map(p => {
                    const statusDot = getProjectStatusIndicator(p.name);
                    const state = getProjectState(p.name);
                    const statusMeta = state && state.status === 'running' ? ' · <span style="color:var(--green)">运行中</span>' : '';
                    const isActive = currentProject === p.name && currentMode === 'code' && !currentAgentId;
                    return `<div class="project-item ${isActive ? 'active' : ''}" onclick="selectProject('${p.name}', 'code')">
                        <div class="name">📁 ${p.name}${statusDot}</div>
                        <div class="meta">${p.file_count} 文件 · ${p.mod_time || '未知'}${statusMeta}</div>
                    </div>`;
                }).join('')
            });
        }

        // 远程项目按 agent 分组
        const codingToolNames = ['claudecode', 'opencode'];
        let agentMap = new Map();

        cachedAllRemote
            .filter(rp => !query || rp.name.toLowerCase().includes(query))
            .forEach(rp => {
                if (!agentMap.has(rp.agent_id)) {
                    agentMap.set(rp.agent_id, { name: rp.agent, entries: [] });
                }
                const g = agentMap.get(rp.agent_id);
                const hasCoding = rp.tools && rp.tools.some(t => codingToolNames.includes(t));
                const hasDeploy = rp.tools && rp.tools.includes('deploy');

                if (hasCoding) {
                    g.entries.push({ name: rp.name, agent_id: rp.agent_id, mode: 'code', icon: '💻' });
                }
                if (hasDeploy) {
                    g.entries.push({ name: rp.name, agent_id: rp.agent_id, mode: 'deploy', icon: '🚀' });
                }
                // pipeline 条目：同一个 deploy agent 的 pipelines
                if (hasDeploy && rp.pipelines && rp.pipelines.length > 0) {
                    rp.pipelines.forEach(pip => {
                        if (!g.entries.some(e => e.mode === 'pipeline' && e.name === pip)) {
                            g.entries.push({ name: pip, agent_id: rp.agent_id, mode: 'pipeline', icon: '🔄' });
                        }
                    });
                }
                if (!hasCoding && !hasDeploy) {
                    g.entries.push({ name: rp.name, agent_id: rp.agent_id, mode: 'code', icon: '📁' });
                }
            });

        agentMap.forEach((g, agentId) => {
            g.entries.sort((a, b) => a.mode.localeCompare(b.mode) || a.name.localeCompare(b.name));
            const itemsHtml = g.entries.map(e => {
                const statusDot = getProjectStatusIndicator(e.name, e.agent_id);
                const state = getProjectState(e.name, e.agent_id);
                const statusMeta = state && state.status === 'running' ? ' · <span style="color:var(--green)">运行中</span>' : '';
                const isActive = currentProject === e.name && currentAgentId === e.agent_id && currentMode === e.mode;
                const modeLabel = e.mode === 'deploy' ? '部署' : e.mode === 'pipeline' ? '编排' : '编码';
                return `<div class="project-item ${isActive ? 'active' : ''}" onclick="selectProject('${e.name}', '${e.mode}', '${e.agent_id}')">
                    <div class="name">${e.icon} ${e.name}${statusDot}</div>
                    <div class="meta">${modeLabel}${statusMeta}</div>
                </div>`;
            }).join('');

            groups.push({
                id: agentId,
                icon: '🖥',
                name: g.name,
                count: g.entries.length,
                html: itemsHtml
            });
        });

        if (groups.length === 0) {
            list.innerHTML = query
                ? '<div style="padding: 20px; color: var(--text-muted); text-align: center; font-size: 13px;">未找到匹配项目</div>'
                : '<div style="padding: 20px; color: var(--text-muted); text-align: center; font-size: 13px;">暂无项目<br>点击 + 新建 创建</div>';
            return;
        }

        // 初次加载时展开第一个组
        if (!initialExpandDone && groups.length > 0) {
            expandedAgents.add(groups[0].id);
            initialExpandDone = true;
        }
        // 搜索时展开所有匹配组
        if (query) {
            groups.forEach(g => expandedAgents.add(g.id));
        }
        // 当前选中项目的组自动展开
        if (currentAgentId) {
            expandedAgents.add(currentAgentId);
        } else if (currentProject && !currentAgentId) {
            expandedAgents.add('__local__');
        }

        let html = '';
        groups.forEach(group => {
            const isExpanded = expandedAgents.has(group.id);
            html += `<div class="agent-group ${isExpanded ? '' : 'collapsed'}" data-group-id="${group.id}">
                <div class="agent-group-header" onclick="toggleAgentGroup('${group.id}')">
                    <span class="arrow">▼</span>
                    <span>${group.icon} ${group.name}</span>
                    <span class="grp-count">${group.count}个</span>
                </div>
                <div class="agent-group-body">
                    ${group.html}
                </div>
            </div>`;
        });

        list.innerHTML = html;
    }

    function selectProject(name, mode, agentId) {
        // 保存当前项目的输出
        if (currentProject) {
            saveCurrentProjectState();
        }

        currentProject = name;
        currentMode = mode || 'code';
        currentAgentId = agentId || null;
        const state = getProjectState(name, currentAgentId);
        currentSessionId = state.sessionId;

        renderProjects();
        document.getElementById('welcomeView').style.display = 'none';
        const output = document.getElementById('outputArea');
        output.classList.add('active');

        // 根据 mode 切换输入区域
        if (currentMode === 'deploy') {
            document.getElementById('codeInputArea').style.display = 'none';
            document.getElementById('deployInputArea').style.display = 'flex';
            document.getElementById('pipelineInputArea').style.display = 'none';
            // 填充部署目标下拉框
            populateDeployTargets(name, agentId);
        } else if (currentMode === 'pipeline') {
            document.getElementById('codeInputArea').style.display = 'none';
            document.getElementById('deployInputArea').style.display = 'none';
            document.getElementById('pipelineInputArea').style.display = 'flex';
        } else {
            document.getElementById('codeInputArea').style.display = 'flex';
            document.getElementById('deployInputArea').style.display = 'none';
            document.getElementById('pipelineInputArea').style.display = 'none';
        }

        // 恢复该项目的输出
        if (state.outputHtml) {
            output.innerHTML = state.outputHtml;
            output.scrollTop = output.scrollHeight;
        } else {
            output.innerHTML = '';
            const modeLabel = currentMode === 'deploy' ? '部署' : currentMode === 'pipeline' ? '编排' : '编码';
            addEvent('system', `📂 已选择${modeLabel}项目: ${name}`);
            if (currentMode !== 'deploy' && currentMode !== 'pipeline') {
                loadProjectReadme(name);
            }
        }

        // 恢复状态栏
        if (state.status === 'running') {
            const runLabel = currentMode === 'deploy' ? '部署中...' : currentMode === 'pipeline' ? '编排中...' : '编码中...';
            setStatus('running', runLabel);
            document.getElementById('btnSend').disabled = true;
            document.getElementById('btnStop').classList.add('visible');
            document.getElementById('btnDeployRun').disabled = true;
            document.getElementById('btnDeployStop').classList.add('visible');
            document.getElementById('btnPipelineRun').disabled = true;
            document.getElementById('btnPipelineStop').classList.add('visible');
            // 重连 WebSocket
            if (currentSessionId) {
                connectWebSocket(currentSessionId);
            }
        } else {
            setStatus('idle', '就绪');
            document.getElementById('costText').textContent = state.costText || '';
            resetUI();
        }

        if (currentMode === 'code') {
            document.getElementById('promptInput').focus();
        }
    }

    // 填充部署目标下拉框（从 remoteProjectMap 获取该 agent 的 deploy_targets）
    function populateDeployTargets(projectName, agentId) {
        const sel = document.getElementById('deployTarget');
        // 保留第一个默认选项，清除其余
        while (sel.options.length > 1) sel.remove(1);

        const entries = remoteProjectMap[projectName] || [];
        for (const rp of entries) {
            if (rp.agent_id === agentId && rp.deploy_targets && rp.deploy_targets.length > 0) {
                rp.deploy_targets.forEach(t => {
                    const opt = document.createElement('option');
                    opt.value = t;
                    opt.textContent = t;
                    sel.appendChild(opt);
                });
                // 添加 "all" 选项
                if (rp.deploy_targets.length > 1) {
                    const allOpt = document.createElement('option');
                    allOpt.value = 'all';
                    allOpt.textContent = '全部目标';
                    sel.appendChild(allOpt);
                }
                break;
            }
        }
    }

    function saveCurrentProjectState() {
        if (!currentProject) return;
        const state = getProjectState(currentProject, currentAgentId);
        state.outputHtml = document.getElementById('outputArea').innerHTML;
        state.costText = document.getElementById('costText').textContent;
    }

    async function loadProjectReadme(project) {
        // 尝试多个常见 README 文件名
        const readmeNames = ['README.md', 'readme.md', 'README', 'readme.txt'];
        for (const name of readmeNames) {
            try {
                const resp = await fetch(`/api/codegen/file?project=${encodeURIComponent(project)}&path=${encodeURIComponent(name)}`);
                const data = await resp.json();
                if (data.success && data.data && data.data.content) {
                    let content = data.data.content;
                    if (content.length > 1000) content = content.substring(0, 1000) + '\n...';
                    addEvent('assistant', `📄 ${name}\n${content}`);
                    return;
                }
            } catch (e) { /* ignore */ }
        }
        // 没有 README
        const area = document.getElementById('outputArea');
        const div = document.createElement('div');
        div.className = 'event-item system';
        div.innerHTML = `📝 该项目暂无 README。<a href="#" style="color: var(--accent); text-decoration: underline;" onclick="suggestReadme(); return false;">点击让 Claude Code 生成一个</a>`;
        area.appendChild(div);
    }

    function suggestReadme() {
        const input = document.getElementById('promptInput');
        input.value = '请分析项目代码，生成一个详细的 README.md，包含项目简介、使用方法、技术栈等信息。';
        input.focus();
    }

    // 新建项目
    function showNewProjectModal() {
        document.getElementById('newProjectModal').classList.add('active');
        document.getElementById('newProjectName').value = '';
        document.getElementById('newProjectName').focus();
    }
    function hideNewProjectModal() {
        document.getElementById('newProjectModal').classList.remove('active');
    }
    async function createProject() {
        const name = document.getElementById('newProjectName').value.trim();
        if (!name) return;
        try {
            const resp = await fetch('/api/codegen/projects', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ name })
            });
            const data = await resp.json();
            if (!data.success) throw new Error(data.error);
            hideNewProjectModal();
            selectProject(name);
            loadProjects();
        } catch (err) {
            alert('创建失败: ' + err.message);
        }
    }

    // 发送编码请求
    async function sendPrompt() {
        const input = document.getElementById('promptInput');
        const prompt = input.value.trim();
        if (!prompt || !currentProject) {
            if (!currentProject) alert('请先选择或创建项目');
            return;
        }

        input.value = '';
        addEvent('user', prompt);
        setStatus('running', '正在启动 Claude Code...');
        document.getElementById('btnSend').disabled = true;
        document.getElementById('btnStop').classList.add('visible');

        const state = getProjectState(currentProject, currentAgentId);
        state.status = 'running';
        renderProjects(); // 更新侧边栏运行指示

        try {
            let endpoint = '/api/codegen/run';
            let selectedModel = document.getElementById('modelSelect').value;
            let selectedTool = document.getElementById('toolSelect').value;
            let body = { project: currentProject, prompt, model: selectedModel, tool: selectedTool, agent_id: currentAgentId || '' };
            let isFollowUp = false;

            if (currentSessionId) {
                // 检查模型或工具是否变更，变更则开新会话
                if ((state.model && state.model !== selectedModel) ||
                    (state.tool !== undefined && state.tool !== selectedTool)) {
                    // 模型/工具切换，开全新会话
                    currentSessionId = null;
                    state.sessionId = null;
                } else {
                    endpoint = '/api/codegen/message';
                    body = { session_id: currentSessionId, prompt };
                    isFollowUp = true;
                }
            }

            const resp = await fetch(endpoint, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(body)
            });
            const data = await resp.json();
            if (!data.success) throw new Error(data.error);

            if (data.data.session_id) {
                currentSessionId = data.data.session_id;
                state.sessionId = currentSessionId;
                state.model = selectedModel;
                state.tool = selectedTool;
            }

            // 连接 WebSocket（追加消息时跳过历史，避免重复显示）
            connectWebSocket(currentSessionId, isFollowUp);
        } catch (err) {
            addEvent('error', '启动失败: ' + err.message);
            state.status = 'error';
            renderProjects();
            resetUI();
        }
    }

    // 执行 Pipeline 编排
    async function runPipeline() {
        if (!currentProject) return;

        addEvent('user', `🔄 执行 Pipeline: ${currentProject}`);
        setStatus('running', '正在执行 Pipeline...');
        document.getElementById('btnPipelineRun').disabled = true;
        document.getElementById('btnPipelineStop').classList.add('visible');

        const state = getProjectState(currentProject, currentAgentId);
        state.status = 'running';
        renderProjects();

        try {
            const body = {
                pipeline: currentProject,
                agent_id: currentAgentId || ''
            };
            const resp = await fetch('/api/codegen/run', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(body)
            });
            const data = await resp.json();
            if (!data.success) throw new Error(data.error);

            currentSessionId = data.data.session_id;
            state.sessionId = currentSessionId;
            connectWebSocket(currentSessionId, false);
        } catch (err) {
            addEvent('error', 'Pipeline 启动失败: ' + err.message);
            state.status = 'error';
            renderProjects();
            resetUI();
        }
    }

    // 直接部署（跳过编码）
    async function deployProject() {
        if (!currentProject) {
            alert('请先选择项目');
            return;
        }

        const deployTarget = document.getElementById('deployTarget').value;
        const buildPlatform = document.getElementById('deployPlatform').value;
        const packOnly = document.getElementById('deployPackOnly').checked;

        // 构建用户提示信息
        const parts = [];
        if (packOnly) parts.push('仅打包');
        else parts.push('部署');
        if (deployTarget) parts.push(`目标: ${deployTarget}`);
        if (buildPlatform) parts.push(`平台: ${buildPlatform}`);
        addEvent('user', `🚀 ${parts.join(' · ')}`);

        setStatus('running', packOnly ? '正在打包...' : '正在部署...');
        document.getElementById('btnDeployRun').disabled = true;
        document.getElementById('btnDeployStop').classList.add('visible');

        const state = getProjectState(currentProject, currentAgentId);
        state.status = 'running';
        renderProjects();

        try {
            const body = {
                project: currentProject,
                deploy_only: true,
                agent_id: currentAgentId || '',
                deploy_target: deployTarget,
                build_platform: buildPlatform,
                pack_only: packOnly
            };
            const resp = await fetch('/api/codegen/run', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(body)
            });
            const data = await resp.json();
            if (!data.success) throw new Error(data.error);

            currentSessionId = data.data.session_id;
            state.sessionId = currentSessionId;
            connectWebSocket(currentSessionId, false);
        } catch (err) {
            addEvent('error', '部署启动失败: ' + err.message);
            state.status = 'error';
            renderProjects();
            resetUI();
        }
    }

    // WebSocket 连接
    function connectWebSocket(sessionId, skipHistory) {
        if (ws) ws.close();
        const protocol = location.protocol === 'https:' ? 'wss:' : 'ws:';
        const wsProject = currentProject; // 捕获当前项目
        const wsAgentId = currentAgentId; // 捕获当前 agent ID
        let wsUrl = `${protocol}//${location.host}/ws/codegen?session_id=${sessionId}`;
        if (skipHistory) {
            wsUrl += '&skip_history=1';
        }
        ws = new WebSocket(wsUrl);

        ws.onmessage = function(e) {
            const event = JSON.parse(e.data);
            const isActiveProject = (currentProject === wsProject && currentAgentId === wsAgentId);

            if (event.type === 'tool') {
                if (isActiveProject) addToolEvent(event);
            } else if (event.type === 'thinking') {
                if (isActiveProject) addThinkingEvent(event.text);
            } else if (event.type === 'assistant') {
                if (isActiveProject) addEvent('assistant', event.text);
            } else if (event.type === 'result') {
                // 只有 done=true 或有 text 时才显示
                if (event.done || (event.text && event.text.trim())) {
                    let summary = event.text || '✅ 编码完成';
                    if (isActiveProject) addEvent('result', summary);
                }
                let stats = [];
                if (event.cost_usd > 0) stats.push(`💰 $${event.cost_usd.toFixed(4)}`);
                if (event.tokens_in > 0 || event.tokens_out > 0) stats.push(`📊 ${event.tokens_in || 0} → ${event.tokens_out || 0} tokens`);
                if (event.duration_ms > 0) stats.push(`⏱ ${(event.duration_ms / 1000).toFixed(1)}s`);
                if (event.num_turns > 0) stats.push(`🔄 ${event.num_turns} turns`);
                if (stats.length > 0) {
                    const statsText = stats.join(' · ');
                    // 只有 done=true 时才在输出区显示统计
                    if (isActiveProject && event.done) {
                        document.getElementById('costText').textContent = statsText;
                        addEvent('system', statsText);
                    }
                    const state = getProjectState(wsProject, wsAgentId);
                    if (event.done) {
                        state.costText = stats.join(' · ');
                    }
                }
            } else if (event.type === 'error') {
                if (isActiveProject) addEvent('error', event.text);
            } else if (event.type === 'summary') {
                if (isActiveProject) addEvent('result', event.text);
            } else if (event.type === 'system') {
                if (isActiveProject) addEvent('system', event.text);
            } else {
                if (isActiveProject) addEvent('system', event.text || JSON.stringify(event));
            }

            // 保存非活跃项目的输出到缓存
            if (!isActiveProject) {
                // 构建事件 HTML 追加到缓存
                const state = getProjectState(wsProject, wsAgentId);
                state.outputHtml += buildEventHtml(event);
            }

            if (event.done) {
                const state = getProjectState(wsProject, wsAgentId);
                state.status = (event.type === 'error') ? 'error' : 'done';
                if (isActiveProject) {
                    if (event.type === 'error') {
                        setStatus('error', '❌ 失败');
                    } else {
                        setStatus('done', '✅ 完成');
                    }
                    resetUI();
                }
                // 保存最终输出
                if (isActiveProject) {
                    saveCurrentProjectState();
                }
                renderProjects(); // 更新侧边栏状态
            } else {
                if (isActiveProject) setStatus('running', '编码中...');
            }
        };

        ws.onerror = function() {
            if (currentProject === wsProject && currentAgentId === wsAgentId) {
                addEvent('error', 'WebSocket 连接失败');
                resetUI();
            }
        };

        ws.onclose = function() {
            // don't overwrite error/done status
        };
    }

    // 构建事件 HTML（用于缓存非活跃项目的输出）
    function buildEventHtml(event) {
        let cls = event.type || 'system';
        let content = '';
        if (event.type === 'user') {
            content = `<strong>👤 你:</strong> ${escapeHtml(event.text || '')}`;
        } else if (event.type === 'thinking') {
            const text = event.text || '';
            const preview = text.length > 80 ? text.substring(0, 80).replace(/\n/g, ' ') + '...' : text.replace(/\n/g, ' ');
            content = `<div class="thinking-header"><span class="toggle-icon">▶</span> 💭 思考: ${escapeHtml(preview)}</div><div class="thinking-content">${escapeHtml(text)}</div>`;
            return `<div class="event-item thinking collapsed" onclick="this.classList.toggle('collapsed')">${content}</div>`;
        } else if (event.type === 'tool') {
            content = buildToolContent(event);
        } else if (event.type === 'result') {
            // 只有 done=true 或有 text 时才记录
            if (!event.done && !(event.text && event.text.trim())) {
                return '';
            }
            content = escapeHtml(event.text || '✅ 编码完成');
        } else {
            content = escapeHtml(event.text || '');
        }
        return content ? `<div class="event-item ${cls}">${content}</div>` : '';
    }

    // 停止会话
    async function stopSession() {
        if (!currentSessionId) return;
        try {
            await fetch('/api/codegen/stop', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ session_id: currentSessionId })
            });
        } catch (err) {
            console.error('Stop failed:', err);
        }
        if (currentProject) {
            const state = getProjectState(currentProject, currentAgentId);
            state.status = 'stopped';
        }
        renderProjects();
        resetUI();
    }

    // 添加工具事件（详细显示）
    function addToolEvent(event) {
        const area = document.getElementById('outputArea');
        const div = document.createElement('div');
        div.className = 'event-item tool';
        div.innerHTML = buildToolContent(event);
        area.appendChild(div);
        area.scrollTop = area.scrollHeight;
    }

    // 添加思考过程事件（可折叠）
    function addThinkingEvent(text) {
        const area = document.getElementById('outputArea');
        const div = document.createElement('div');
        div.className = 'event-item thinking collapsed';
        const preview = text.length > 80 ? text.substring(0, 80).replace(/\n/g, ' ') + '...' : text.replace(/\n/g, ' ');
        div.innerHTML = `<div class="thinking-header"><span class="toggle-icon">▶</span> 💭 思考: ${escapeHtml(preview)}</div><div class="thinking-content">${escapeHtml(text)}</div>`;
        div.addEventListener('click', function() {
            div.classList.toggle('collapsed');
        });
        area.appendChild(div);
        area.scrollTop = area.scrollHeight;
    }

    // 构建工具详细内容
    function buildToolContent(event) {
        const name = event.tool_name || 'unknown';
        let input = event.tool_input || '';
        
        // 优先使用后端生成的 Text（已格式化）
        if (event.text && event.text.trim()) {
            return `<div class="tool-header">🔧 ${escapeHtml(name)}</div><div class="tool-detail">${escapeHtml(event.text)}</div>`;
        }

        // 否则尝试解析 tool_input
        let detail = '';
        try {
            const parsed = JSON.parse(input);
            detail = formatToolDetail(name, parsed);
        } catch (e) {
            detail = input;
        }

        return `<div class="tool-header">🔧 ${escapeHtml(name)}</div><div class="tool-detail">${escapeHtml(detail)}</div>`;
    }

    // 根据工具类型格式化详细参数
    function formatToolDetail(toolName, params) {
        // 兼容不同字段名
        const filePath = params.filePath || params.file_path || params.path || '';
        const cmd = params.command || params.cmd || '';
        
        switch (toolName.toLowerCase()) {
            case 'write':
            case 'write_file':
                return `文件: ${filePath}${params.content ? '\n内容:\n' + (params.content.length > 500 ? params.content.substring(0, 500) + '...' : params.content) : ''}`;
            case 'read':
            case 'read_file':
                return `文件: ${filePath}${params.offset ? '  offset=' + params.offset : ''}${params.limit ? '  limit=' + params.limit : ''}`;
            case 'edit':
            case 'edit_file':
                let s = `文件: ${filePath}`;
                if (params.old_string) s += `\n查找:\n${params.old_string}`;
                if (params.new_string) s += `\n替换:\n${params.new_string}`;
                return s;
            case 'bash':
            case 'run_command':
                return `命令: ${cmd}${params.description ? '\n说明: ' + params.description : ''}`;
            case 'glob':
                return `模式: ${params.pattern || ''}${params.path ? '  路径: ' + params.path : ''}`;
            case 'grep':
            case 'search':
                return `模式: ${params.pattern || ''}${params.path ? '  路径: ' + params.path : ''}${params.glob ? '  文件: ' + params.glob : ''}`;
            case 'listdir':
            case 'list_dir':
                return `路径: ${params.path || '.'}`;
            default:
                // 通用：显示所有参数
                return Object.entries(params).map(([k, v]) => {
                    const val = typeof v === 'string' ? (v.length > 500 ? v.substring(0, 500) + '...' : v) : JSON.stringify(v);
                    return `${k}: ${val}`;
                }).join('\n');
        }
    }

    // UI 工具函数
    function addEvent(type, text) {
        const area = document.getElementById('outputArea');
        const div = document.createElement('div');
        div.className = `event-item ${type}`;
        
        if (type === 'user') {
            div.innerHTML = `<strong>👤 你:</strong> ${escapeHtml(text)}`;
        } else {
            div.textContent = text;
        }
        
        area.appendChild(div);
        area.scrollTop = area.scrollHeight;
    }

    function setStatus(state, text) {
        const dot = document.getElementById('statusDot');
        dot.className = `status-dot ${state === 'running' ? 'running' : ''}`;
        document.getElementById('statusText').textContent = text;
    }

    function resetUI() {
        document.getElementById('btnSend').disabled = false;
        document.getElementById('btnStop').classList.remove('visible');
        document.getElementById('btnDeployRun').disabled = false;
        document.getElementById('btnDeployStop').classList.remove('visible');
        document.getElementById('btnPipelineRun').disabled = false;
        document.getElementById('btnPipelineStop').classList.remove('visible');
    }

    function escapeHtml(text) {
        const div = document.createElement('div');
        div.textContent = text;
        return div.innerHTML;
    }
    </script>
</body>
</html>
