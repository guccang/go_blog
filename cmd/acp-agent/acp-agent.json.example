{
  "port": 8888,
  "max_clients": 100,
  "log_level": "info",
  "agent_base_config": {
    "name": "acp-agent",
    "version": "1.0.0",
    "description": "ACP Protocol Agent for Cloud Code integration"
  },
  "cloud_code": {
    "enabled": true,
    "host": "localhost",
    "port": 8080,
    "api_key": "your-cloud-code-api-key",
    "timeout": 30
  },
  "client_code_x": {
    "enabled": true,
    "protocol": "ws",
    "endpoint": "ws://localhost:8081/ws",
    "auth_token": "your-client-code-x-token"
  }
}