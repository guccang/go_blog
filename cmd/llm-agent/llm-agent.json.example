{
  "gateway_url": "ws://127.0.0.1:10086/ws/uap",
  "gateway_http": "http://127.0.0.1:10086",
  "auth_token": "your-auth-token",
  "agent_id": "llm-agent",
  "agent_name": "LLM-Agent",

  "providers": {
    "deepseek": {
      "base_url": "https://api.deepseek.com/v1",
      "api_key": "your-deepseek-api-key"
    },
    "openai": {
      "base_url": "https://api.openai.com/v1",
      "api_key": "your-openai-api-key"
    }
  },

  "llm": {
    "provider": "deepseek",
    "model": "deepseek-chat",
    "max_tokens": 4096,
    "temperature": 0.7
  },
  "fallbacks": [
    {"provider": "openai", "model": "gpt-4o", "max_tokens": 4096, "temperature": 0.7}
  ],

  "default_account": "your-account",
  "workspace_dir": "workspace"
}
