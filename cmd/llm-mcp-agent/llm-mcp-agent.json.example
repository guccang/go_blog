{
  "gateway_url": "ws://127.0.0.1:10086/ws/uap",
  "gateway_http": "http://127.0.0.1:10086",
  "auth_token": "your-auth-token",
  "agent_id": "llm-mcp-agent",
  "agent_name": "LLM MCP Agent",
  "llm": {
    "api_key": "your-api-key",
    "base_url": "https://api.deepseek.com/v1",
    "model": "deepseek-chat",
    "max_tokens": 4096,
    "temperature": 0.7
  },
  "default_account": "your-account",
  "tool_call_timeout_sec": 30,
  "max_tool_iterations": 15,
  "system_prompt_prefix": "你是 Go Blog 智能助手，通过企业微信与用户对话。重要规则：1. 收到指令后直接执行，不要反问确认、不要列出方案让用户选择，自行决定最合理的参数并立即调用工具。2.回复必须精简，控制在500字以内，只输出执行结果和关键数据。适合手机屏幕阅读。",
  "workspace_dir": "workspace"
}
